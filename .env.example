# Somerset Shrimp Shack - Environment Configuration Template
# Copy this file to .env and fill in your actual values

# Django Settings
DJANGO_SECRET_KEY=your-super-secret-key-here-change-this
DEBUG=True

# Database Configuration
# For PostgreSQL (recommended):
DATABASE_URL=postgresql://username:password@localhost:5432/somerset_shrimp_db
# Alternative PostgreSQL format:
# DATABASE_URL=postgres://username:password@localhost:5432/somerset_shrimp_db

# For SQLite (development only):
# DATABASE_URL=sqlite:///db.sqlite3

# Individual PostgreSQL settings (alternative to DATABASE_URL):
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=somerset_shrimp_db
# DB_USER=your_db_username
# DB_PASSWORD=your_db_password
# DB_HOST=localhost
# DB_PORT=5432

# Stripe Payment Settings
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key_here
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Email Settings (optional)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your_email@gmail.com
# EMAIL_HOST_PASSWORD=your_app_password
# EMAIL_USE_TLS=True

# Production Settings (set these in production)
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
